{
  "name": "handsfree-cooking",
  "version": "1.0.0",
  "description": "A Web Component for handsfree voice-controlled recipe navigation using the Web Speech API",
  "type": "module",
  "main": "dist/handsfree-cooking.iife.js",
  "module": "dist/handsfree-cooking.js",
  "exports": {
    ".": {
      "import": "./dist/handsfree-cooking.js",
      "default": "./dist/handsfree-cooking.iife.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,vue}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "web-component",
    "voice-control",
    "speech-recognition",
    "handsfree",
    "cooking",
    "recipe"
  ],
  "license": "MIT",
  "dependencies": {
    "hark": "^1.2.3",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "vite": "^7.1.10",
    "vitest": "^4.1.2"
  }
}
